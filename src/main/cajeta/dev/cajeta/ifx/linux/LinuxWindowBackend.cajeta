package dev.cajeta.ifx.linux;

import cajeta.ifx.WindowBackend;
import cajeta.ifx.Window;
import cajeta.ifx.Surface;
import cajeta.ifx.WindowEvent;
import cajeta.ifx.BackendRegistry;

/**
 * LinuxWindowBackend — the Linux window/surface backend for ifx, FFI-binding Wayland (primary) + X11/XCB (fallback).
 * Registers itself so the ifx dispatcher can select it on Linux. v0.1 skeleton — no FFI yet.
 *
 * Audio (PipeWire (primary) + PulseAudio + ALSA) and input (libinput / evdev (+ udev)) backends are sibling classes in this library; see
 * documents/cajeta-ifx-linux-plan.md.
 */
public final class LinuxWindowBackend implements WindowBackend {

    /** Called at load to register this backend with ifx. */
    public static void register() {
        BackendRegistry.registerWindow(new LinuxWindowBackend());
    }

    public boolean probe()    { return false; }       // TODO: detect the Linux environment
    public int32   priority() { return 100; }
    public String  name()     { return "linux"; }

    public Window createWindow(String title, uint32 width, uint32 height) {
        return null;   // TODO: create a window via Wayland (primary) + X11/XCB (fallback)
    }

    public Surface surfaceOf(Window w) {
        return null;   // TODO: opaque surface handle for VK_KHR_wayland_surface / VK_KHR_xcb_surface
    }

    public WindowEvent[] poll(Window w) {
        return null;   // TODO: drain the Linux event queue
    }

    public void destroy(Window w) { }
}
